<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.example.demo.mapper.ScenicSpotMapper">
    <resultMap id="ScenicSpotMap" type="com.example.demo.entity.ScenicSpot">
        <id column="id" property="id"/>
        <result column="name" property="name"/>
        <result column="region" property="region"/>
        <result column="category" property="category"/>
        <result column="description" property="description"/>
        <result column="address" property="address"/>
        <result column="price" property="price"/>
        <result column="rating" property="rating"/>
        <result column="cover_image_url" property="coverImageUrl"/>
        <result column="create_time" property="createTime"/>
        <result column="update_time" property="updateTime"/>
    </resultMap>

    <select id="selectById" resultMap="ScenicSpotMap">
        SELECT * FROM scenic_spot WHERE id = #{id}
    </select>

    <!-- 查询所有不重复的地区 -->
    <select id="getRegions" resultType="java.lang.String">
        SELECT DISTINCT region
        FROM scenic_spot
        WHERE region IS NOT NULL
        AND region != ''
        ORDER BY region
    </select>



    <!-- 按城市分页查询景点 -->
    <select id="selectByCityPage" resultType="com.example.demo.entity.ScenicSpot">
        SELECT *
        FROM scenic_spot
        WHERE 1=1
        <if test="city != null and city != ''">
            AND region = #{city}
        </if>
        ORDER BY create_time DESC
        LIMIT #{offset}, #{pageSize}
    </select>

    <!-- 查询按城市筛选后的总条数 -->
    <select id="selectCountByCity" resultType="java.lang.Long">
        SELECT COUNT(*)
        FROM scenic_spot
        WHERE 1=1
        <if test="city != null and city != ''">
            AND region = #{city}
        </if>
    </select>

    <select id="countById" resultType="java.lang.Integer">
        SELECT COUNT(*) FROM scenic_spot WHERE id = #{id}
    </select>


</mapper>